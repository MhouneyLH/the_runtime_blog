---
import { stat } from "node:fs/promises";
import { Image } from "astro:assets";
import { FileTree } from "@astrojs/starlight/components";
import { getCollection } from "astro:content";
import { getReadingTime } from "../utils/reading-time";

const entries = (await getCollection("docs")).filter((entry) => entry.id !== "index");
const pinnedEntries = entries.filter(
  (entry) => (entry.data as { pinned?: boolean }).pinned === true,
);

const pinnedEntriesWithDates = await Promise.all(
  pinnedEntries.map(async (entry) => {
    const frontmatterDate = (entry.data as { date?: Date }).date;
    let createdAt: number | null = frontmatterDate ? frontmatterDate.getTime() : null;

    if (!createdAt && entry.filePath) {
      const stats = await stat(entry.filePath);
      createdAt = stats.birthtimeMs || stats.mtimeMs;
    }

    if (!createdAt) {
      return { entry, comment: null };
    }

    const formattedDate = new Date(createdAt).toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "2-digit",
    });
    return { entry, comment: formattedDate };
  }),
);

const readingTimes = new Map(
  pinnedEntries.map((entry) => [entry.id, getReadingTime(entry.body)]),
);
---

<section class="pinned-section">
  {
    pinnedEntries.length > 0 ? (
      <FileTree>
        <ul>
          <li>
            src/
            <ul>
              <li>
                pinned/
                <ul>
                  {pinnedEntriesWithDates.map(({ entry, comment }) => (
                    <li>
                      {entry.data.cover && (
                        <Image
                          src={entry.data.cover}
                          alt=""
                          width={48}
                          height={48}
                          class="entry-thumb"
                        />
                      )}
                      <a href={`/${entry.id}/`}>{entry.data.title}</a>
                      {comment && <> {comment}</>}
                      {" "}· {readingTimes.get(entry.id)} min read
                      {entry.data.tags && entry.data.tags.length > 0 && (
                        <span class="tag-list">
                          {entry.data.tags.map((tag: string) => (
                            <span class="tag">{tag}</span>
                          ))}
                        </span>
                      )}
                    </li>
                  ))}
                </ul>
              </li>
            </ul>
          </li>
        </ul>
      </FileTree>
    ) : (
      <p class="pinned-empty">No pinned articles yet.</p>
    )
  }
</section>

<style>
  .tag-list {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-left: 0.5rem;
  }

  .tag {
    font-size: 0.7rem;
    line-height: 1;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: var(--sl-color-gray-5);
    color: var(--sl-color-gray-2);
  }

  .entry-thumb {
    width: 2rem;
    height: 2rem;
    object-fit: cover;
    border-radius: 0.375rem;
    margin-inline-end: 0.5rem;
    flex-shrink: 0;
  }
</style>
